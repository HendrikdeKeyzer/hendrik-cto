# =============================================================================
# Hendrik energie dashboard — local config
# =============================================================================
# Copy this file to .env and fill in the values. .env is gitignored.
#
# WARNING: anything starting with VITE_ is bundled into the public JS at build
# time. Don't deploy a build with real tokens to a public host. For Task 1.3
# (GitHub Pages) we'll need a backend proxy that holds the secrets server-side.

# -----------------------------------------------------------------------------
# ENTSO-E Transparency Platform — wholesale day-ahead prices
# -----------------------------------------------------------------------------
# How to get a token (free, ~3 working days):
#   1. Register at https://transparency.entsoe.eu/
#   2. Confirm email
#   3. Email transparency@entsoe.eu, subject "Restful API access", body
#      requesting RESTful API access for your account
#   4. They reply within ~3 working days
#   5. My Account → Web API Security Token
VITE_ENTSOE_TOKEN=

# -----------------------------------------------------------------------------
# Home Assistant — live solar/battery/consumption data
# -----------------------------------------------------------------------------
# Base URL of your HA instance (no trailing slash). Defaults match Hendrik's
# public hostname; override for a different setup.
VITE_HA_BASE=https://ha.richardheesen.nl

# Long-lived access token. In HA: profile (bottom-left) → Long-Lived Access Tokens.
VITE_HA_TOKEN=

# Sensor entity IDs. Defaults match Hendrik's Enphase Envoy installation.
# Override per-entity if you have a different inverter brand.
VITE_HA_PRODUCTION_W=sensor.envoy_122503008953_current_power_production
VITE_HA_CONSUMPTION_W=sensor.envoy_122503008953_current_power_consumption
VITE_HA_NET_W=sensor.envoy_122503008953_current_net_power_consumption
VITE_HA_PRODUCTION_TODAY_WH=sensor.envoy_122503008953_today_s_energy_production
VITE_HA_CONSUMPTION_TODAY_WH=sensor.envoy_122503008953_today_s_energy_consumption
VITE_HA_BATTERY_PCT=sensor.envoy_122503008953_total_battery_percentage

# Price sensors from the EnergyZero HA integration. Used by RevenueCard.
VITE_HA_PRICE_NOW=sensor.energyzero_today_energy_current_hour_price
VITE_HA_PRICE_AVG=sensor.energyzero_today_energy_average_price
