# ENTSO-E Transparency Platform security token.
#
# How to get one (free, ~3 working days):
#   1. Register an account at https://transparency.entsoe.eu/
#   2. Confirm email
#   3. Email transparency@entsoe.eu with subject "Restful API access"
#      and body "Please grant me access to the RESTful API for account
#      <your-email>". They reply within a few working days.
#   4. Once approved, find your token at My Account → Web API Security Token
#
# Copy this file to .env and paste your token below.
VITE_ENTSOE_TOKEN=
