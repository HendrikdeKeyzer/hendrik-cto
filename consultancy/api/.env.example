# NREL PVWatts API key (free at https://developer.nrel.gov/signup/)
PVWATTS_API_KEY=your_nrel_api_key_here

# Stripe keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (for sending reports) — use SendGrid or SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hendrik@example.com
SMTP_PASS=your_app_password

# Hendrik's email (where all lead notifications go)
HENDRIK_EMAIL=hendrik@example.com

# CORS origin for frontend (update to actual domain in production)
CORS_ORIGIN=http://localhost:5173
